-- YABUJIN - PlayerGui Version (Not CoreGui)
local player = game.Players.LocalPlayer
local gui = Instance.new("ScreenGui")
gui.Name = "Yabujin"
gui.Parent = player:WaitForChild("PlayerGui")  -- Different from CoreGui

-- Crosshair
local crosshair = Instance.new("Frame")
crosshair.Size = UDim2.new(0, 20, 0, 20)
crosshair.Position = UDim2.new(0.5, -10, 0.48, -10)
crosshair.BackgroundTransparency = 1
crosshair.Parent = gui

local lineH = Instance.new("Frame")
lineH.Size = UDim2.new(0, 14, 0, 2)
lineH.Position = UDim2.new(0.5, -7, 0.5, -1)
lineH.BackgroundColor3 = Color3.fromRGB(255, 80, 200)
lineH.Parent = crosshair

local lineV = Instance.new("Frame")
lineV.Size = UDim2.new(0, 2, 0, 14)
lineV.Position = UDim2.new(0.5, -1, 0.5, -7)
lineV.BackgroundColor3 = Color3.fromRGB(255, 80, 200)
lineV.Parent = crosshair

-- Unlock function
local function unlockWeapons()
    pcall(function()
        local pg = player:WaitForChild("PlayerGui")
        for _, v in pairs(pg:GetDescendants()) do
            if v:IsA("ImageButton") or v:IsA("TextButton") then
                v.Visible = true
                local lock = v:FindFirstChild("LockIcon") or v:FindFirstChild("Lock")
                if lock then lock.Visible = false end
            end
        end
    end)
    print("Weapons unlocked!")
end

-- Main Window
local window = Instance.new("Frame")
window.Size = UDim2.new(0, 300, 0, 350)
window.Position = UDim2.new(0.5, -150, 0.5, -175)
window.BackgroundColor3 = Color3.fromRGB(18, 18, 24)
window.BackgroundTransparency = 0
window.BorderSizePixel = 0
window.Parent = gui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 10)
corner.Parent = window

local titleBar = Instance.new("Frame")
titleBar.Size = UDim2.new(1, 0, 0, 35)
titleBar.BackgroundColor3 = Color3.fromRGB(255, 80, 200)
titleBar.BackgroundTransparency = 0.3
titleBar.Parent = window

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -50, 1, 0)
title.Position = UDim2.new(0, 10, 0, 0)
title.BackgroundTransparency = 1
title.Text = "YABUJIN"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.TextSize = 18
title.Font = Enum.Font.GothamBold
title.TextXAlignment = Enum.TextXAlignment.Left
title.Parent = titleBar

local close = Instance.new("TextButton")
close.Size = UDim2.new(0, 30, 0, 30)
close.Position = UDim2.new(1, -35, 0, 3)
close.BackgroundColor3 = Color3.fromRGB(255, 50, 100)
close.Text = "X"
close.TextColor3 = Color3.fromRGB(255, 255, 255)
close.TextSize = 14
close.Font = Enum.Font.GothamBold
close.Parent = titleBar
close.MouseButton1Click:Connect(function() gui:Destroy() end)

local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1, -10, 1, -45)
scroll.Position = UDim2.new(0, 5, 0, 40)
scroll.BackgroundTransparency = 1
scroll.CanvasSize = UDim2.new(0, 0, 0, 400)
scroll.ScrollBarThickness = 4
scroll.Parent = window

local layout = Instance.new("UIListLayout")
layout.Padding = UDim.new(0, 5)
layout.Parent = scroll

local function addBtn(text, color, cb)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 35)
    btn.BackgroundColor3 = color
    btn.BackgroundTransparency = 0.3
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamSemibold
    btn.Parent = scroll
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 5)
    c.Parent = btn
    btn.MouseButton1Click:Connect(cb)
end

local function addLbl(text)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -10, 0, 22)
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(255, 100, 200)
    lbl.TextSize = 11
    lbl.Font = Enum.Font.GothamBold
    lbl.Parent = scroll
end

addLbl("🔓 UNLOCK")
addBtn("UNLOCK ALL WEAPONS", Color3.fromRGB(255, 80, 200), function()
    unlockWeapons()
    local n = Instance.new("TextLabel")
    n.Size = UDim2.new(0, 200, 0, 25)
    n.Position = UDim2.new(0.5, -100, 0, 50)
    n.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    n.Text = "✓ WEAPONS UNLOCKED!"
    n.TextColor3 = Color3.fromRGB(100, 255, 100)
    n.TextSize = 11
    n.Font = Enum.Font.Gotham
    n.Parent = gui
    wait(1.5)
    n:Destroy()
end)

addLbl("━━ CHARACTER ━━")
addBtn("Pink Skin", Color3.fromRGB(255, 80, 200), function()
    local char = player.Character
    if char then
        for _, p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                p.Color = Color3.fromRGB(255, 80, 200)
                p.Material = Enum.Material.Neon
            end
        end
    end
end)
addBtn("Cyan Skin", Color3.fromRGB(0, 255, 255), function()
    local char = player.Character
    if char then
        for _, p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                p.Color = Color3.fromRGB(0, 255, 255)
                p.Material = Enum.Material.Neon
            end
        end
    end
end)
addBtn("Gold Skin", Color3.fromRGB(255, 200, 0), function()
    local char = player.Character
    if char then
        for _, p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                p.Color = Color3.fromRGB(255, 200, 0)
                p.Material = Enum.Material.Metal
            end
        end
    end
end)

addLbl("━━ WEAPON ━━")
addBtn("Pink Weapon", Color3.fromRGB(255, 80, 200), function()
    local char = player.Character
    if char then
        local tool = char:FindFirstChildOfClass("Tool")
        if tool then
            for _, p in pairs(tool:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.Color = Color3.fromRGB(255, 80, 200)
                    p.Material = Enum.Material.Neon
                end
            end
        end
    end
end)
addBtn("Cyan Weapon", Color3.fromRGB(0, 255, 255), function()
    local char = player.Character
    if char then
        local tool = char:FindFirstChildOfClass("Tool")
        if tool then
            for _, p in pairs(tool:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.Color = Color3.fromRGB(0, 255, 255)
                    p.Material = Enum.Material.Neon
                end
            end
        end
    end
end)

addLbl("━━ CROSSHAIR ━━")
addBtn("Hide Crosshair", Color3.fromRGB(100, 100, 120), function() crosshair.Visible = false end)
addBtn("Show Crosshair", Color3.fromRGB(100, 200, 100), function() crosshair.Visible = true end)
addBtn("Pink", Color3.fromRGB(255, 80, 200), function()
    lineH.BackgroundColor3 = Color3.fromRGB(255, 80, 200)
    lineV.BackgroundColor3 = Color3.fromRGB(255, 80, 200)
end)
addBtn("Cyan", Color3.fromRGB(0, 255, 255), function()
    lineH.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
    lineV.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
end)

addLbl("━━ RESET ━━")
addBtn("Reset Skins", Color3.fromRGB(150, 150, 50), function()
    local char = player.Character
    if char then
        for _, p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                p.Color = Color3.fromRGB(255, 255, 255)
                p.Material = Enum.Material.Plastic
            end
        end
        local tool = char:FindFirstChildOfClass("Tool")
        if tool then
            for _, p in pairs(tool:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.Color = Color3.fromRGB(255, 255, 255)
                    p.Material = Enum.Material.Plastic
                end
            end
        end
    end
end)
addBtn("Destroy GUI", Color3.fromRGB(200, 50, 50), function() gui:Destroy() end)

-- Auto-unlock
unlockWeapons()

-- Draggable
local drag = false
local dragStart, startPos
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        drag = true
        dragStart = input.Position
        startPos = window.Position
    end
end)
titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
end)
game:GetService("UserInputService").InputChanged:Connect(function(input)
    if drag and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        window.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

print("✅ YABUJIN LOADED - PlayerGui Version")
